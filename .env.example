# AITutor Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# Claude API (get from console.anthropic.com)
ANTHROPIC_API_KEY=your_key_here

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/aitutor_db

# JWT Secret (generate a random 32-char string)
JWT_SECRET=your_random_secret_here
JWT_EXPIRE_HOURS=24

# App Settings
APP_NAME="கல்வி AI"
SCHOOL_NAME="Government Higher Secondary School"
SCHOOL_CODE="GHS001"
PILOT_CLASSES=8,9

# YouTube (no key needed for embedding, only for search API)
YOUTUBE_API_KEY=optional_for_search

# Environment
ENV=development
DEBUG=true
